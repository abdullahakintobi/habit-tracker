# Byte-compiled / optimized files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/

# Test & tooling caches
.pytest_cache/
.coverage
htmlcov/

# Runtime database (generated on first run)
*.db
*.sqlite
*.sqlite3

# Node (presentation deck generator)
node_modules/
npm-debug.log*

# Presentation (Phase-2 build tooling & deck) — a portfolio artifact, not part
# of the app, so it is kept out of the code repository.
presentation/

# Submission assembly (ZIP staging, abstract) — not part of the app
submission/

# OS / editor cruft
.DS_Store
.idea/
.vscode/
